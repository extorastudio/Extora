# =============================================================================
# Extora Core — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# --- Required ---

# PostgreSQL connection string
DATABASE_URL=postgresql://extora:extora@localhost:5432/extora

# Redis connection string
REDIS_URL=redis://localhost:6379

# JWT signing secret (generate: openssl rand -hex 64)
JWT_SECRET=change-me-use-openssl-rand-hex-64

# Encryption key for secrets at rest (generate: openssl rand -hex 32)
ENCRYPTION_KEY=change-me-use-openssl-rand-hex-32

# --- Optional (with defaults) ---

NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# Session time-to-live
SESSION_TTL=15m
REFRESH_TOKEN_TTL=7d

# Rate limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# --- Object Storage ---
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage

# S3/MinIO (used when STORAGE_BACKEND=s3)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=extora
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Search ---
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USER=admin
OPENSEARCH_PASSWORD=Admin123!

# --- Email ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@extora.dev

# --- Marketplace ---
MARKETPLACE_API_URL=https://marketplace.extora.dev/api
MARKETPLACE_API_KEY=

# --- Registry ---
REGISTRY_URL=https://registry.extora.dev

# --- Telemetry (OpenTelemetry) ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=extora-core
