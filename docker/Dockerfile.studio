# Extora Nginx — serves published site + Studio admin panel + API proxy
FROM nginx:alpine

# Studio admin panel (served at /admin-panel/)
COPY apps/studio/dist /usr/share/nginx/studio
RUN mkdir -p /usr/share/nginx/published

# Nginx config
COPY docker/nginx.conf /etc/nginx/nginx.conf

EXPOSE 80

HEALTHCHECK --interval=10s --timeout=3s --retries=5 \
  CMD wget -qO- http://127.0.0.1:80/ || exit 1
